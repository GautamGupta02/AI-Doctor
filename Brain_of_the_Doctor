from dotenv import load_dotenv
load_dotenv()

import os
import base64
from groq import Groq

# Load API key
GROQ_API_KEY = os.environ.get("GROQ_API_KEY")
if not GROQ_API_KEY:
    raise ValueError("GROQ_API_KEY not found")

# Shared Groq client
client = Groq(api_key=GROQ_API_KEY)


# Image Encoding

def encode_image(image_path):
    with open(image_path, "rb") as f:
        return base64.b64encode(f.read()).decode("utf-8")


# Domain Detection (NEW)

def detect_domain_from_image(encoded_image):
    """
    Detect whether the image is related to Human Health or Crop Disease.
    Returns exactly one of:
    - 'Human Health'
    - 'Crop Disease'
    """

    messages = [
        {
            "role": "user",
            "content": [
                {
                    "type": "text",
                    "text": (
                        "Classify this image strictly as either Human Health or Crop Disease. "
                        "Respond with only one of these exact phrases and nothing else."
                    )
                },
                {
                    "type": "image_url",
                    "image_url": {
                        "url": f"data:image/jpeg;base64,{encoded_image}"
                    }
                }
            ]
        }
    ]

    response = client.chat.completions.create(
        model="meta-llama/llama-4-scout-17b-16e-instruct",
        messages=messages
    )

    result = response.choices[0].message.content.strip()

    if result in ["Human Health", "Crop Disease"]:
        return result

    # Safe fallback
    return "Human Health"


def analyze_image_with_query(query, model, encoded_image):
    """
    Main vision + reasoning call
    """

    messages = [
        {
            "role": "user",
            "content": [
                {"type": "text", "text": query},
                {
                    "type": "image_url",
                    "image_url": {
                        "url": f"data:image/jpeg;base64,{encoded_image}"
                    }
                }
            ]
        }
    ]

    response = client.chat.completions.create(
        model=model,
        messages=messages
    )

    return response.choices[0].message.content

